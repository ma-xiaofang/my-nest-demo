# 复制本文件为 `.env` 后按环境填写（勿将含真实密钥的 `.env` 提交到 Git）
# cp .env.example .env   （Windows 可复制并重命名）

# ─── 数据库（必填）───
# Prisma CLI（migrate / generate）与 Nest 的 PrismaService 均使用此连接串
DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/DATABASE_NAME?schema=public"

# ─── HTTP 服务 ───
# 未设置时 Nest 默认监听 3001；若与 `ui/vite.config.ts` 里代理端口一致，请改成相同端口（例如 3009）
SERVER_PORT=3009

# ─── LLM（DeepSeek OpenAI 兼容接口）───
# 聊天功能需要有效的 API Key
DEEPSEEK_API_KEY=

# 可选；默认 https://api.deepseek.com
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# 可选；默认 deepseek-chat
# DEEPSEEK_MODEL=deepseek-chat

# ─── 其它（可选）───
# 应用展示名等，见 `src/app.service.ts`
# APP_NAME=my-nest-demo
